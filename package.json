{
  "name": "apollo-simple-cache",
  "version": "0.5.0",
  "engines": {
    "node": ">=20"
  },
  "description": "Simple cache features for Apollo Client",
  "author": "jet (ジェット)",
  "license": "MIT",
  "homepage": "https://github.com/jet2jet/apollo-simple-cache",
  "keywords": [
    "cache",
    "apollo",
    "apollo-client",
    "Apollo Client",
    "graphql"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jet2jet/apollo-simple-cache.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jet2jet"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.cts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/cjs/index.d.cts"
      ],
      "v3": [
        "./dist/cjs/index.d.cts"
      ],
      "v4": [
        "./dist/cjs-v4/index.d.cts"
      ]
    }
  },
  "// For Apollo Client 3, we always use CommonJS on Node.js due to importing Apollo Client modules": "",
  "exports": {
    ".": {
      "node": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      },
      "import": {
        "default": "./dist/esm/index.mjs",
        "types": "./dist/esm/index.d.mts"
      },
      "require": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      },
      "default": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      }
    },
    "./v3": {
      "node": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      },
      "import": {
        "default": "./dist/esm/index.mjs",
        "types": "./dist/esm/index.d.mts"
      },
      "require": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      },
      "default": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      }
    },
    "./v4": {
      "import": {
        "default": "./dist/esm-v4/index.mjs",
        "types": "./dist/esm-v4/index.d.mts"
      },
      "require": {
        "default": "./dist/cjs-v4/index.cjs",
        "types": "./dist/cjs-v4/index.d.cts"
      },
      "default": {
        "default": "./dist/cjs-v4/index.cjs",
        "types": "./dist/cjs-v4/index.d.cts"
      }
    }
  },
  "imports": {
    "#main-v3/*.mts": "./src/main/*.mts",
    "#main-v4/*.mts": "./src/main-v4/*.mts",
    "#test-common/*.mts": "./src/test-common/*.mts"
  },
  "scripts": {
    "build": "npm run build:v3 && npm run build:v4",
    "build:v3": "npm run build:v3:esm && npm run build:v3:esm:dts && npm run build:v3:cjs && npm run build:v3:cjs:dts",
    "build:v3:esm": "babel src/main --extensions \".mts\" --out-file-extension \".mjs\" -d dist/esm",
    "build:v3:esm:dts": "tsc --project src/main/tsconfig.json --emitDeclarationOnly && node scripts/renameDmtsToDcts.mjs dist/esm mjs",
    "build:v3:cjs": "babel src/main --config-file ./babel.config.cjs.json --extensions \".mts\" --out-file-extension \".cjs\" -d dist/cjs",
    "build:v3:cjs:dts": "tsc --project src/main/tsconfig.cjs.json --emitDeclarationOnly && node scripts/renameDmtsToDcts.mjs dist/cjs cjs",
    "build:v4": "npm run build:v4:esm && npm run build:v4:esm:dts && npm run build:v4:cjs && npm run build:v4:cjs:dts",
    "build:v4:esm": "babel src/main-v4 --extensions \".mts\" --out-file-extension \".mjs\" -d dist/esm-v4",
    "build:v4:esm:dts": "tsc --project src/main-v4/tsconfig.json --emitDeclarationOnly && node scripts/renameDmtsToDcts.mjs dist/esm-v4 mjs",
    "build:v4:cjs": "babel src/main-v4 --config-file ./babel.config.cjs.json --extensions \".mts\" --out-file-extension \".cjs\" -d dist/cjs-v4",
    "build:v4:cjs:dts": "tsc --project src/main-v4/tsconfig.cjs.json --emitDeclarationOnly && node scripts/renameDmtsToDcts.mjs dist/cjs-v4 cjs",
    "benchmark": "tsx --tsconfig src/test/tsconfig.json --experimental-test-module-mocks --import ./src/test/setupTest.mts src/test/benchmark/main.mts",
    "lint": "npm run lint:eslint && npm run lint:prettier",
    "lint:fix": "npm run lint:eslint:fix && npm run lint:prettier:fix",
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "typecheck": "npm run typecheck:main && npm run typecheck:main-v4 && npm run typecheck:test && npm run typecheck:test-v4 && echo \"Done.\"",
    "typecheck:main": "tsc --project src/main/tsconfig.json --noEmit",
    "typecheck:main-v4": "tsc --project src/main-v4/tsconfig.json --noEmit",
    "typecheck:test": "tsc --project src/test/tsconfig.json --noEmit",
    "typecheck:test-v4": "tsc --project src/test-v4/tsconfig.json --noEmit",
    "test": "npm run test:v3 && npm run test:v4",
    "test:v3": "npm run test:v3:base -- \"src/test/**/*.test.mts\"",
    "test:v3:base": "glob -c \"tsx --experimental-test-module-mocks --import ./src/test/setupTest.mts --test\"",
    "test:v4": "npm run test:v4:base -- \"src/test-v4/**/*.test.mts\"",
    "test:v4:base": "glob -c \"tsx --experimental-test-module-mocks --import ./src/test-v4/setupTest.mts --test\""
  },
  "dependencies": {
    "@wry/equality": "^0.5.7"
  },
  "devDependencies": {
    "@apollo/client": "^3.13.9",
    "@apollo/client-v4": "npm:@apollo/client@^4.2.6",
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.19.43",
    "@types/react": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "babel-plugin-transform-rewrite-imports": "^1.5.3",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-n": "^17.21.0",
    "eslint-plugin-promise": "^7.2.1",
    "glob-bin": "^1.1.0",
    "jsdom": "^29.1.1",
    "neostandard": "^0.12.2",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "tinybench": "^4.0.1",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0"
  },
  "peerDependencies": {
    "@apollo/client": "^3.13.8 || ^4",
    "graphql": "^15.0.0 || ^16.0.0 || ^17.0.0"
  }
}
